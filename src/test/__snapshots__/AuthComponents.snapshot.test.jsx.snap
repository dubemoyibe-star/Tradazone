              >
                <p>
                  Crypto invoicing for subscription teams.
                </p>
              </div>
            </div>
          </div>
          <span
            class="text-xs text-t-muted"
          >
            Supports bold, italic, and bullet lists. The draft is sanitized for security.
          </span>
        </div>
        <p
          class="mt-3 text-xs font-medium text-brand"
        >
          Your latest description draft will be attached to your new profile.
        </p>
      </div>
      <button
        class="w-full inline-flex items-center justify-center gap-2 px-4 py-2.5 h-10 bg-brand text-white text-sm font-semibold hover:opacity-90 active:scale-95 transition-all mb-4 rounded-lg"
      >
        Connect Wallet
      </button>
      <button
        aria-label="Export signup data to CSV"
        class="w-full inline-flex items-center justify-center gap-2 px-4 py-2.5 h-10 bg-gray-100 text-gray-700 text-sm font-semibold hover:bg-gray-200 active:scale-95 transition-all mb-6 rounded-lg"
      >
        <svg
          aria-hidden="true"
          class="lucide lucide-download"
          fill="none"
          height="16"
          stroke="currentColor"
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          viewBox="0 0 24 24"
          width="16"
          xmlns="http://www.w3.org/2000/svg"
        >
          <path
            d="M12 15V3"
          />
          <path
            d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"
          />
          <path
            d="m7 10 5 5 5-5"
          />
        </svg>
        Export to CSV
      </button>
    </div>
    <div
      class="hidden lg:block lg:w-[60%] bg-gray-50 relative overflow-hidden"
    >
      <img
        alt="Tradazone — invoices, payments, crypto"
        class="absolute inset-0 w-full h-full object-cover"
        src="auth-splash.svg"
      />
    </div>
  </div>
</div>
`;
