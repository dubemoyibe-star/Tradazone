// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`Auth module snapshots - SignIn > matches snapshot for unauthenticated state with no recent wallet 1`] = `
<div
  class="min-h-screen flex flex-col"
>
  <div
    class="flex flex-1"
  >
    <div
      class="w-full lg:w-[40%] flex flex-col justify-start px-6 py-8 lg:px-10 lg:py-10 bg-white overflow-y-auto"
    >
      <div
        class="mb-8 lg:mb-12"
      >
        <img
          alt="Tradazone"
          class="object-contain h-7 lg:h-9"
          src="logo-blue.png"
        />
      </div>
      <h1
        class="text-xl lg:text-3xl font-bold text-t-primary mb-3 leading-snug"
      >
        Manage clients, send invoices, and accept payments directly into your preferred wallet
      </h1>
      <p
        class="text-sm text-t-muted mb-8 lg:mb-10"
      >
        Connect your wallet to get started
      </p>
      <div
        class="mb-6 rounded-xl border border-border bg-gray-50/80 p-4"
      >
        <div
          class="mb-3"
        >
          <h2
            class="text-sm font-semibold text-t-primary"
          >
            Business description draft
          </h2>
          <p
            class="text-xs text-t-muted"
          >
            Add formatted context about your business before you connect. Tradazone keeps this draft on this device and syncs it into your profile after the next successful wallet session.
          </p>
        </div>
        <div
          class="flex flex-col gap-1.5 "
        >
          <label
            class="text-xs font-medium text-t-secondary uppercase tracking-wide"
            for="signin-business-description"
          >
            Business Description
          </label>
          <div
            class="border rounded-lg bg-white border-border"
          >
            <div
              class="flex flex-wrap items-center gap-2 px-3 py-2 border-b border-border bg-gray-50 rounded-t-lg"
            >
              <button
                aria-label="Bold"
                class="inline-flex min-w-8 items-center justify-center rounded-md border border-border bg-white px-2 py-1 text-xs font-semibold text-t-secondary hover:border-brand hover:text-brand"
                type="button"
              >
                B
              </button>
              <button
                aria-label="Italic"
                class="inline-flex min-w-8 items-center justify-center rounded-md border border-border bg-white px-2 py-1 text-xs font-semibold text-t-secondary hover:border-brand hover:text-brand"
                type="button"
              >
                I
              </button>
              <button
                aria-label="Bullets"
                class="inline-flex min-w-8 items-center justify-center rounded-md border border-border bg-white px-2 py-1 text-xs font-semibold text-t-secondary hover:border-brand hover:text-brand"
                type="button"
              >
                List
              </button>
              <button
                aria-label="Clear formatting"
                class="inline-flex min-w-8 items-center justify-center rounded-md border border-border bg-white px-2 py-1 text-xs font-semibold text-t-secondary hover:border-brand hover:text-brand"
                type="button"
              >
                Clear
              </button>
            </div>
            <div
              class="relative"
            >
              <span
                class="pointer-events-none absolute left-3 top-3 text-sm text-t-muted"
              >
                Describe your business, products, or services before connecting...
              </span>
              <div
                aria-label="Business Description"
                aria-multiline="true"
                class="min-h-36 px-3 py-3 text-sm text-t-primary outline-none"
                contenteditable="true"
                id="signin-business-description"
                role="textbox"
              />
            </div>
          </div>
          <span
            class="text-xs text-t-muted"
          >
            Supports bold, italic, and bullet lists. The draft is sanitized before it is stored.
          </span>
        </div>
      </div>
      <button
        class="w-full inline-flex items-center justify-center gap-2 px-4 py-2.5 h-10 bg-brand text-white text-sm font-semibold hover:opacity-90 active:scale-95 transition-all mb-4 rounded-lg"
      >
        Connect Wallet
      </button>
      <button
        aria-label="Export authentication data to CSV"
        class="w-full inline-flex items-center justify-center gap-2 px-4 py-2.5 h-10 bg-gray-100 text-gray-700 text-sm font-semibold hover:bg-gray-200 active:scale-95 transition-all mb-6 rounded-lg"
      >
        Export to CSV
      </button>
    </div>
    <div
      class="hidden lg:block lg:w-[60%] bg-gray-50 relative overflow-hidden"
    >
      <img
        alt="Tradazone — invoices, payments, crypto"
        class="absolute inset-0 w-full h-full object-cover"
        src="auth-splash.svg"
      />
    </div>
  </div>
</div>
`;

